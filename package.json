{
  "name": "freightflow-pro",
  "version": "1.0.0",
  "description": "FreightFlow PRO — Freight Forwarding Management System (sea freight, FCL/LCL, export-focused)",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node tests/db.test.js",
    "db:init": "node src/db/schema.js",
    "db:seed": "node src/db/seed.js",
    "db:reset": "node src/db/reset.js",
    "electron": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.5.31",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.3.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "nodemon": "^2.0.22"
  },
  "build": {
    "appId": "com.freightflow.pro",
    "productName": "FreightFlow PRO",
    "directories": { "output": "dist" },
    "files": [
      "public/**/*",
      "src/**/*",
      "server.js",
      "main.js",
      "package.json",
      ".env"
    ],
    "extraResources": [ { "from": "data", "to": "data" } ],
    "win": { "target": "nsis", "icon": "build/icon.ico" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
